#!/usr/bin/env bash
#
# Guard public CastCodes surfaces against accidental Warp reintroduction.
# This intentionally does not scan the full repository: internal crate names,
# upstream dependency URLs, protocol markers, tests, and historical specs still
# retain Warp names during this staged external rebrand.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

scan_paths=(
  README.md
  FAQ.md
  CONTRIBUTING.md
  SECURITY.md
  CODE_OF_CONDUCT.md
  CASTCODES.md
  Cargo.toml
  app/Cargo.toml
  app/src/bin/oss.rs
  app/channels
  script/run
  script/macos/run
  script/macos/bundle
  script/update_plist
  script/Entitlements.plist
  script/linux/bundle
  script/linux/bundle_appimage
  script/linux/bundle_arch
  script/linux/bundle_deb
  script/linux/bundle_install
  script/linux/bundle_rpm
  script/windows/bundle.ps1
  script/windows/windows-installer.iss
  resources/linux/arch/app
  resources/linux/debian/app
  resources/linux/rpm/app
  .github/ISSUE_TEMPLATE
  .github/PULL_REQUEST_TEMPLATE
  .github/pull_request_template.md
)

# Paths inside the app crate where user-visible strings live. We only scan
# *quoted string literals* here (see the in-string pattern below) so that
# internal Rust identifiers (WarpDrive, WarpifyPageView, EditorChoice::Warp,
# WARP_* env vars, etc.) remain untouched per the staged rebrand policy.
app_src_paths=(
  app/src/app_menus.rs
  app/src/root_view.rs
  app/src/quit_warning
  app/src/workspace/view.rs
  app/src/workspace/mod.rs
  app/src/workspace/cli_install.rs
  app/src/workspace/view
  app/src/workspace/hoa_onboarding
  app/src/settings_view
  app/src/terminal/input.rs
  app/src/resource_center
  app/src/auth
  app/src/billing
  app/src/wasm_nux_dialog.rs
  app/src/themes/default_themes.rs
  app/src/themes/theme.rs
  app/src/uri/browser_url_handler.rs
  app/src/uri/mod.rs
  app/src/ai_assistant
  app/src/tips/tip_view.rs
)

patterns=(
  'Warp'
  'warp\.dev'
  'warpdotdev'
  'dev\.warp'
  '\.warp'
  'warp-terminal'
  'warp-oss'
  'warp://'
)

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

for pattern in "${patterns[@]}"; do
  rg -n --hidden --glob '!*.png' --glob '!*.ico' --glob '!*.bmp' --glob '!*.icns' \
    "$pattern" "${scan_paths[@]}" >> "$tmp" || true
done

# Scan in-app Rust source for "Warp" appearing inside quoted string literals
# only. Internal identifiers (types, enum variants, env vars, log keys, file
# paths) are out of scope by design. Exclude tests.
rg -n --type rust --glob '!**/*_tests.rs' --glob '!**/tests/**' \
  '"[^"]*\bWarp\b[^"]*"' "${app_src_paths[@]}" >> "$tmp" || true

if [[ ! -s "$tmp" ]]; then
  echo "CastCodes rebrand guard passed."
  exit 0
fi

allowed='(^WARP.md:|script/macos/bundle:[0-9]+:.*WARP_|script/macos/bundle:[0-9]+:.*WarpDockTilePlugin|script/macos/run:[0-9]+:.*WARP_|script/run:[0-9]+:.*WARP_|script/linux/bundle:[0-9]+:.*WARP_|script/linux/bundle_appimage:[0-9]+:.*WARP_|script/windows/bundle\.ps1:[0-9]+:.*WARP_|script/windows/windows-installer\.iss:[0-9]+:.*WARP_CLI_MODE|app/src/bin/oss\.rs:[0-9]+:.*WarpServerConfig|app/Cargo\.toml:[0-9]+:.*package\.metadata\.bundle\.bin\.warp|app/Cargo\.toml:[0-9]+:.*open_warp_|app/Cargo\.toml:[0-9]+:.*warpify_|app/Cargo\.toml:[0-9]+:.*warpdotdev/|Cargo\.toml:[0-9]+:.*warpdotdev/|app/src/settings_view/mod\.rs:[0-9]+:.*backward compatibility|app/src/settings_view/mod\.rs:[0-9]+:.*"WarpDrive" \| "Warp Drive"|app/src/settings_view/mod\.rs:[0-9]+:.*"Oz" \| "Warp Agent"|app/src/ai_assistant/mod\.rs:[0-9]+://!.*renamed to "Warp AI")'

violations="$(grep -Ev "$allowed" "$tmp" || true)"

if [[ -n "$violations" ]]; then
  echo "CastCodes rebrand guard failed. Unapproved public Warp references remain:" >&2
  echo "$violations" >&2
  exit 1
fi

echo "CastCodes rebrand guard passed with intentional compatibility allowances."
