#!/usr/bin/env bash
#
# Guard CastCodes against generated-by / model-credit artifacts.
# Product docs may mention supported AI tools as functionality; this check is
# intentionally scoped to attribution/provenance phrasing.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

patterns=(
  '🤖[[:space:]]*Generated with'
  '\bGenerated (with|by)[[:space:]]+(\[[^]]+\][(][^)]+[)]|Claude|Claude Code|Codex|ChatGPT|OpenAI|Gemini|Copilot|Cursor|Windsurf|Replit Agent|Devin)\b'
  '\bCreated (with|by)[[:space:]]+(Claude|Claude Code|Codex|ChatGPT|OpenAI|Gemini|Copilot|Cursor|Windsurf|Replit Agent|Devin)\b'
  '\bMade (with|by)[[:space:]]+(Claude|Claude Code|Codex|ChatGPT|OpenAI|Gemini|Copilot|Cursor|Windsurf|Replit Agent|Devin)\b'
  '\bPowered by AI\b'
  '(?i)^Co-authored-by:.*\b(Claude|Claude Code|Codex|ChatGPT|OpenAI|Gemini|Copilot|Cursor|Windsurf|Replit Agent|Devin)\b'
)

for pattern in "${patterns[@]}"; do
  rg -n --hidden --pcre2 \
    --glob '!target/**' \
    --glob '!node_modules/**' \
    --glob '!.git/**' \
    --glob '!script/check_ai_attribution' \
    --glob '!AGENTS.md' \
    --glob '!resources/bundled/skills/**' \
    --glob '!resources/bundled/mcp_skills/**' \
    "$pattern" . >> "$tmp" || true
done

# Commit-message scan. The file-content scan above only catches attribution that
# lives in tracked files; an agent that follows the default `Co-Authored-By: ...`
# trailer for git commits would slip past it. Scan commit-message bodies of
# commits ahead of the base ref (default: origin/main) against the same patterns.
#
# Override the base ref with AI_ATTRIBUTION_BASE_REF for CI or non-standard
# setups. Skips silently when no usable base ref exists (fresh clone, detached
# HEAD on the base itself, etc.) so the existing file-scan behavior is preserved.
if git rev-parse --git-dir >/dev/null 2>&1; then
  base_ref="${AI_ATTRIBUTION_BASE_REF:-}"
  if [[ -z "$base_ref" ]]; then
    for candidate in origin/main main origin/master master; do
      if git rev-parse --verify --quiet "$candidate" >/dev/null; then
        base_ref="$candidate"
        break
      fi
    done
  fi

  if [[ -n "$base_ref" ]] && git rev-parse --verify --quiet "$base_ref" >/dev/null; then
    while IFS= read -r sha; do
      [[ -z "$sha" ]] && continue
      body="$(git log -1 --pretty=format:%B "$sha")"
      for pattern in "${patterns[@]}"; do
        # Emit one prefixed line per matching message line.
        if matched="$(printf '%s\n' "$body" | rg --pcre2 --no-line-number --no-filename "$pattern" 2>/dev/null)"; then
          while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            printf '[commit-msg %s] %s\n' "$sha" "$line" >> "$tmp"
          done <<< "$matched"
        fi
      done
    done < <(git log "$base_ref..HEAD" --pretty=tformat:%H 2>/dev/null || true)
  fi
fi

if [[ ! -s "$tmp" ]]; then
  echo "AI attribution guard passed."
  exit 0
fi

echo "AI attribution guard failed. Remove generated-by/model-credit artifacts:" >&2
cat "$tmp" >&2
exit 1
